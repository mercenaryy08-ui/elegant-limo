# Copy to .env and fill in. All optional.

# Google Maps: for address autocomplete and map (Switzerland). Get a key at https://console.cloud.google.com/
# VITE_GOOGLE_MAPS_API_KEY=

# Mapbox (optional): for map tiles, routing, and address autocomplete (Switzerland).
# Get a public token at https://account.mapbox.com/
# VITE_MAPBOX_ACCESS_TOKEN=pk_xxxxx
# Optional: custom Mapbox style ID (e.g. mapbox/light-v11 or your own style)
# VITE_MAPBOX_STYLE_ID=mapbox/light-v11

# Backend API base URL. When empty, booking emails use same-origin /api/send-booking-emails (e.g. on Vercel).
# VITE_API_BASE_URL=

# Ops dashboard password (free protection, no backend). If set, /ops requires this password.
# VITE_OPS_PASSWORD=

# --- Brevo (booking confirmation emails) - set in Vercel Dashboard for production ---
# Get API key: https://app.brevo.com/settings/keys/api
# BREVO_API_KEY=xkeysib-xxxxx
# Optional: sender shown in emails (must be a verified sender in Brevo)
# BREVO_SENDER_EMAIL=noreply@elegant-limo.ch
# BREVO_SENDER_NAME=Elegant Limo Switzerland
# ADMIN_EMAIL=booking@elegant-limo.ch
# General contact inbox (used on website/contact pages): info@elegant-limo.ch

# WhatsApp number for "Contact us" links (no +). Used in confirmation email and success page.
# WHATSAPP_NUMBER=38348263151

# --- reCAPTCHA v2 (before payment) - set both for production ---
# Get keys: https://www.google.com/recaptcha/admin (reCAPTCHA v2 "I'm not a robot" checkbox)
# VITE_RECAPTCHA_SITE_KEY is SAFE to expose: it's the public "site" key (Google docs). Only RECAPTCHA_SECRET_KEY must stay server-only.
# VITE_RECAPTCHA_SITE_KEY=6LeBkXssAAAAAD9Q-_K02uScONxGmkBNohhVcYV1
# RECAPTCHA_SECRET_KEY=your_secret_key_from_google  (never commit the real secret; set in Vercel Dashboard)

# --- Stripe (pay on website) - set in Vercel Dashboard for production ---
# See STRIPE_SETUP.md and SECURITY.md. Use sk_test_... for testing, sk_live_... for live.
# STRIPE_SECRET_KEY=sk_test_xxxxx  (required for checkout; never commit; mark sensitive in Vercel)
# Optional: Vite only reads VITE_* in the frontend. Publishable key not used by current redirect flow.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx  (only if you add Stripe.js / Payment Element later)
# Optional but recommended for production: restrict redirect URLs (comma-separated hostnames)
# ALLOWED_ORIGINS=elegant-limo.ch,booking.elegant-limo.ch
